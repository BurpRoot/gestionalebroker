# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
API_PREFIX=/api/v1

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/gestionalebroker"

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Session ──────────────────────────────────────────────────────────────────
SESSION_SECRET="cambia-questa-stringa-con-qualcosa-di-lungo-e-casuale"
SESSION_MAX_AGE_MS=28800000
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAME_SITE=lax

# ─── File Uploads ─────────────────────────────────────────────────────────────
UPLOAD_BASE_PATH="./uploads"
UPLOAD_MAX_FILE_SIZE_MB=20
UPLOAD_ALLOWED_MIME_TYPES="application/pdf,image/jpeg,image/png,image/webp"

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGIN="http://localhost:5173"

# ─── Bcrypt ───────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=debug
